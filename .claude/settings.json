{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git push)",
      "Bash(git push origin main)",
      "Bash(git push origin main:main)",
      "Bash(git push --set-upstream origin *)",
      "Bash(git push -u origin *)"
    ]
  }
}
